<?xml version="1.0"?>
<!-- Sets a password on the default ClickHouse user.
     Applied on every container start (not just fresh init).
     Keep this in sync with CLICKHOUSE_PASS in .env. -->
<clickhouse>
    <users>
        <default>
            <password>tejas@123</password>
            <networks>
                <ip>::/0</ip>
            </networks>
            <profile>default</profile>
            <quota>default</quota>
            <access_management>1</access_management>
        </default>
    </users>
</clickhouse>
