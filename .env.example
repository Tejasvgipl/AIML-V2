# CyberSentinel v2 — Environment Variables
# Copy: cp .env.example .env  then fill in real values

# ── AI / Groq ─────────────────────────────────────────────────────────────────
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# ── Threat Intel ──────────────────────────────────────────────────────────────
ABUSEIPDB_KEY=your_key_here

# ── ClickHouse (runs as Docker service, no external box needed) ───────────────
CLICKHOUSE_ENABLED=true
CLICKHOUSE_PASS=tejas@123

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=cs-jwt-secret-CHANGE-IN-PROD-2026
SEED_ADMIN_USER=Tejas
SEED_ADMIN_PASS=tejas@123

# ── Log level ─────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Host ports (19xxx — free on server, no clash with v1 or Wazuh stack) ─────
NGINX_HOST_PORT=19888
FRONTEND_HOST_PORT=19180
BACKEND_HOST_PORT=19110
ML_ENGINE_HOST_PORT=19111
AUTH_HOST_PORT=19113
CLICKHOUSE_HTTP_PORT=19123
CLICKHOUSE_NATIVE_PORT=19000
GRAFANA_PORT=19300

# ── Wazuh log tail (wazuh profile only) ───────────────────────────────────────
WAZUH_ALERTS_PATH=/var/ossec/logs/alerts/alerts.json
