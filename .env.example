# CyberSentinel Environment Variables
# Copy this to .env and fill in real values

# Optional: AbuseIPDB API key for live threat intel
# Get free key at https://www.abuseipdb.com/register
ABUSEIPDB_KEY=your_key_here

# Optional: AI API key for generated analyst explanations
# Put the real value only in .env
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Redis password (leave blank for local dev)
REDIS_PASSWORD=

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Host ports. These high defaults avoid common SOC/Wazuh/OpenSearch ports.
REDIS_HOST_PORT=16380
BACKEND_HOST_PORT=18110
ML_ENGINE_HOST_PORT=18111
ML_INTERN_HOST_PORT=18112
FRONTEND_HOST_PORT=18180
NGINX_HOST_PORT=18888

# ML Intern hybrid retraining controls
ML_INTERN_CHECK_MINUTES=5
ML_INTERN_TIME_HOURS=24
ML_INTERN_NEW_LOG_THRESHOLD=10000
ML_INTERN_DRIFT_THRESHOLD=0.35
ML_INTERN_MIN_TRAINING_IPS=5

# OpenSearch persistent store (already running on Wazuh/.23 server)
# Set OPENSEARCH_ENABLED=true to dual-write logs to Redis + OpenSearch
OPENSEARCH_ENABLED=false
OPENSEARCH_HOST=10.200.10.23
OPENSEARCH_PORT=9200
OPENSEARCH_USER=admin
OPENSEARCH_PASS=admin
OS_BULK_SIZE=200
OS_FLUSH_INTERVAL=5.0
